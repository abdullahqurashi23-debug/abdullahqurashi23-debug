# PSO Pump Management System - Production Environment Variables
# Copy this file to .env and update the values before running docker-compose

# Database Password (REQUIRED - change this!)
DB_PASSWORD=your_secure_database_password_here

# JWT Secrets (REQUIRED - change these!)
JWT_SECRET=your-super-long-random-jwt-secret-key-for-production
JWT_REFRESH_SECRET=your-super-long-random-refresh-secret-key-for-production
